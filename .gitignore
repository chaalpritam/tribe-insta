# Xcode build output
build/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Project.yml is the source of truth, but the generated .xcodeproj is
# committed so a fresh clone opens directly in Xcode without needing
# xcodegen installed. Re-run `xcodegen generate` after editing Project.yml
# (it produces deterministic GUIDs so the diff stays small).

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.pins
# Keep Package.resolved for Xcode GUI package resolution.
# tribe-core-swift symlink is monorepo-only (see `make setup`).
tribe-core-swift

# macOS
.DS_Store
.AppleDouble
.LSOverride

